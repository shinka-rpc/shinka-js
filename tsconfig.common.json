{
  "compilerOptions": {
    "target": "es2017",
    "module": "es2015",
    "lib": ["DOM", "DOM.Iterable", "es2017"],
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  "exclude": [
    // "**/*.test.ts",
    // "**/*.stub.ts",
    "node_modules/",
    "dist/"
  ]
}
