{
  "compilerOptions": {
    "target": "ES2016",
    "module": "es2015",
    "lib": ["DOM", "DOM.Iterable", "ES2017"],
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types"]
  },
  "exclude": [
    // "**/*.test.ts",
    // "**/*.stub.ts",
    "node_modules/",
    "dist/"
  ]
}
